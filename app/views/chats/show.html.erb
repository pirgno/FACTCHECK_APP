<div class="chat-page">
  <div class="container retour ml-3">
    <%= link_to "← Retour aux actualités", news_index_path, class: "news-back-link" %>
  </div>
  <div class="chat-container">

    <div class="chat-header">
      <div>
        <p class="chat-badge">Analyse IA</p>
        <h1><%= @chat.title %></h1>
      </div>
    </div>

    <div id="messages" class="messages-container">

      <% @chat.messages.each do |message| %>

        <% if message.role == "user" %>

          <div class="message-row user-row">
            <div class="message-bubble user-bubble">
              <%= render_markdown(message.content) %>
            </div>
          </div>

        <% elsif message.role == "assistant" %>

          <div class="message-row assistant-row">

            <div class="assistant-avatar">
              🤖
            </div>

            <div class="assistant-card">

              <% verdict_class = case message.verdict.to_s.upcase
                   when "VRAI", "PLUTÔT VRAI" then "bg-success text-white"
                   when "FAUX", "PLUTÔT FAUX" then "bg-danger text-white"
                   when "PARTIELLEMENT VRAI" then "bg-warning text-dark"
                   else "bg-secondary text-white"
                   end %>

              <div class="fact-header">
                <div class="fact-meta">
                  <span class="status-badge <%= verdict_class %>"><%= message.verdict || "NON VÉRIFIABLE" %></span>
                  <% if message.category.present? %>
                    <span class="category-pill"><%= message.category %></span>
                  <% end %>
                </div>

                <% if message.confidence_level.present? %>
                  <p class="confidence-note">
                    Niveau de confiance de l'analyse :
                    <strong><%= message.confidence_level %></strong>
                  </p>
                <% end %>
              </div>

              <div class="truth-bar">
                <div class="truth-bar-fill" style="width: <%= message.truth_percentage || 0 %>%"></div>
              </div>
              <p class="truth-percentage-label">
                Véracité : <strong><%= message.truth_percentage || 0 %>%</strong>
              </p>

              <% if message.name.present? %>
                <h2 class="claim-title"><%= message.name %></h2>
              <% end %>

              <div class="assistant-content">
                <%= render_markdown(message.content) %>
              </div>

              <% if message.origin.present? %>
                <p class="origin-note">
                  <strong>Origine —</strong> <%= message.origin %>
                </p>
              <% end %>

              <% if message.tags&.any? %>
                <div class="tags-row">
                  <% message.tags.each do |tag| %>
                    <span class="tag-chip">#<%= tag %></span>
                  <% end %>
                </div>
              <% end %>

              <div class="save-button-wrapper">
                <%= button_to "Sauvegarder", saved_messages_path,
                  params: { message_id: message.id },
                  class: "save-button" %>
              </div>
            </div>

          </div>

        <% end %>

      <% end %>

    </div>

    <div class="new-message-wrapper">

      <%= simple_form_for [@chat, @message], html: {
        data: { controller: "submit-on-enter" }
      } do |f| %>

        <div class="fake-chat-input">

          <%= f.input :content,
          label: false,
          required: true,
          placeholder: "Pose ta question...",
          input_html: { data: { action: "keydown->submit-on-enter#submitOnEnter" } } %>

          <%= f.button :submit, "➜", class: "send-button" %>

        </div>

      <% end %>

    </div>

  </div>

</div>
