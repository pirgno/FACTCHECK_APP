<section class="home-hero">
  <div class="home-hero-content">
    <p class="hero-badge">IA · Vérification instantanée</p>

    <h1>
      Vérifie les faits.<br>
      Partage la <span>vérité.</span>
    </h1>

    <p class="hero-subtitle">
      factcheck analyse les informations, vérifie les sources
      et t’aide à distinguer le vrai du faux.
    </p>

    <%= link_to new_user_session_path, class: "fake-search-bar" do %>
      <span class="search-icon">⌕</span>
      <span class="fake-placeholder">Pose ta question ou colle un lien...</span>
      <span class="fake-search-button">Vérifier</span>
    <% end %>

    <p class="login-note">
      Connecte-toi pour lancer une vérification.
    </p>
  </div>
</section>
