<div class="devise-links mt-4">

  <%- if controller_name != 'sessions' %>
    <div class="mb-3">
      <%= link_to "Se connecter", new_session_path(resource_name), class: "devise-link" %>
    </div>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <div class="mb-3">
      <%= link_to "S’inscrire", new_registration_path(resource_name), class: "devise-link" %>
    </div>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <div class="mb-3">
      <%= link_to "Mot de passe oublié ?", new_password_path(resource_name), class: "devise-link forgot-password" %>
    </div>
  <% end %>

</div>
