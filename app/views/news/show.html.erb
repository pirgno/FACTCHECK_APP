<% content_parts = @news.content.split("## SOURCES") %>
<% explanation = content_parts[0].gsub("## EXPLICATION", "").strip %>
<% sources = content_parts[1].to_s.strip.split("•").reject(&:blank?) %>

<div class="container my-5 news-show-page">
  <%= link_to "← Retour aux actualités", news_index_path, class: "news-back-link" %>

  <div class="row mt-5">
    <div class="col-12 col-lg-7">
      <span class="badge rounded-pill bg-danger mb-3">
        <%= @news.verdict %>
      </span>

      <h1 class="news-show-title"><%= @news.name %></h1>

      <p class="news-show-category">
        Catégorie : <strong><%= @news.category %></strong>
      </p>

      <div class="card news-score-card my-4">
        <div class="card-body">
          <p class="mb-1">Véracité</p>
          <h2><%= @news.truth_percentage %>%</h2>

          <div class="truth-bar">
            <div class="truth-bar-fill" style="width: <%= @news.truth_percentage %>%"></div>
          </div>
        </div>
      </div>

      <h2 class="news-section-title">Résumé</h2>

      <div class="news-content">
        <%= simple_format(explanation) %>
      </div>

      <div class="news-sources-section mt-5">
        <h2 class="news-section-title">Sources</h2>

        <div class="source-card">
          <ul class="sources-list">
            <% sources.each do |source| %>
              <li><%= source.strip %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>

    <div class="col-12 col-lg-4 offset-lg-1 mt-4 mt-lg-0">
      <div class="card news-side-card">
        <div class="card-body">
          <h2 class="news-section-title">Pourquoi c’est faux ?</h2>

          <div class="news-content">
            <%= simple_format(explanation) %>
          </div>

          <div class="news-key-points mt-4">
            <p>
              <i class="fa-solid fa-circle-info"></i>
              <span>Verdict : <strong><%= @news.verdict %></strong></span>
            </p>

            <p>
              <i class="fa-solid fa-chart-simple"></i>
              <span>Véracité : <strong><%= @news.truth_percentage %>%</strong></span>
            </p>

            <p>
              <i class="fa-solid fa-tag"></i>
              <span>Catégorie : <strong><%= @news.category %></strong></span>
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
